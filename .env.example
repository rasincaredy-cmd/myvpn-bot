# --- Telegram ---
BOT_TOKEN=

# Список Telegram user_id админов через запятую (минимум один — твой)
ADMIN_IDS=

# --- БД ---
# По умолчанию SQLite в ./data/vpn_bot.sqlite3
DB_URL=sqlite+aiosqlite:///./data/vpn_bot.sqlite3

# --- Шифрование SSH-кредов в БД ---
# Сгенерировать: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=

# --- Логирование ---
LOG_LEVEL=INFO

# --- SSH ---
SSH_CONNECT_TIMEOUT=20
SSH_COMMAND_TIMEOUT=900

# --- AmneziaWG ---
# Порт по умолчанию, рекомендация документации Amnezia: 585 или 1234
DEFAULT_AMNEZIA_PORT=585
